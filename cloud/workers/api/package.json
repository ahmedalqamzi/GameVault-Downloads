{
  "name": "@gamevault/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply gamevault --local",
    "db:migrate:remote": "wrangler d1 migrations apply gamevault --remote",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@gamevault/shared": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.39.0"
  }
}
